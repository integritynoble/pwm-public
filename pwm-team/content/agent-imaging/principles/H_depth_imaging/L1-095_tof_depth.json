  "E": {
    "description": "A NIR source is amplitude-modulated at frequency f_mod (10-100 MHz). Light reflected from the scene picks up a round-trip phase shift phi = 4*pi*f_mod*d/c. Four-bucket demodulation at the pixel extracts in-phase and quadrature components, from which phi and amplitude are computed. Depth d = c * phi / (4*pi*f_mod), with wrap ambiguity c/(2*f_mod). Multi-frequency captures resolve wraps.",
    "forward_model": "I_k(u,v) = A(u,v) * cos(phi(u,v) - psi_k) + B(u,v) + n_k(u,v),  k = 0..3",
    "world_state_x": "Depth map d(u,v) in R^{H x W} (and optionally amplitude map A(u,v))",
    "observation_y": "4 (or 8) demodulation buckets per pixel y(u,v,k) in R^{H x W x K}",
    "physical_parameters_theta": [
      "Modulation frequency f_mod (10-100 MHz)",
      "Demodulation phases psi_k (typ 0, pi/2, pi, 3pi/2)",
      "Integration time T_int, ambient rejection",
      "Sensor quantum efficiency, pixel pitch, IR filter",
      "Multipath interference (MPI) model"
    ]
  },
  "G": {
    "dag": "L.modulate.amcw -> L.reflect_scene -> L.demodulate -> int.temporal",
    "vertices": [
      "L.modulate.amcw",
