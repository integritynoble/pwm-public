  "E": {
    "description": "A camera captures K images at distinct exposures t_k of a high-dynamic-range scene with irradiance E(u,v). Each frame y_k passes through the camera response function g (typically non-linear, per-channel) and saturates at the ADC limit. HDR reconstruction recovers E and (optionally) inverts g.",
    "forward_model": "y_k(u,v) = clip(g(t_k * E(u,v)) + n_k(u,v), 0, 2^B - 1), k = 1..K exposures",
    "world_state_x": "HDR irradiance map E(u,v) in R^{H x W} spanning 10^4 - 10^6 dynamic range",
    "observation_y": "K LDR frames y_k in R^{H x W x 3}, typically 8-bit or 10-bit",
    "physical_parameters_theta": [
      "Exposure times {t_k}, k = 1..K (typically spaced by 2 stops each)",
      "Camera response function g(.) per color channel",
      "Sensor bit depth B (8 / 10 / 12 / 14)",
      "Read noise + shot noise model, gain, vignetting",
      "Inter-frame motion / scene motion (ghosting source)"
    ]
  },
  "G": {
    "dag": "S.scan.exposure -> L.apply.crf -> D.saturate -> int.temporal",
    "vertices": [
      "S.scan.exposure",
