  "E": {
    "description": "Ptychography acquires J overlapping far-field diffraction intensities I_j as a coherent probe P scans across a complex object O on a regular or random grid. Each intensity is the phaseless squared magnitude of the Fourier transform of the product probe*object patch. The high inter-patch overlap (60-80%) creates redundancy that jointly constrains probe and object phases.",
    "forward_model": "I_j(k) = |F{P(r - r_j) * O(r)}|^2 + n_j(k),  j = 1..J",
    "world_state_x": "Complex object O(r) in C^{H x W} (amplitude and phase); jointly recovered with complex probe P(r) in C^{P x P}",
    "observation_y": "J diffraction patterns I_j in R^{K x K} (non-negative intensities; Poisson photon counting)",
    "physical_parameters_theta": [
      "Probe P(r): complex illumination function",
      "Scan positions {r_j}: grid + sub-pixel jitter",
      "Wavelength lambda, propagation distance z, detector pixel size dx",
      "Scan overlap fraction (typical 0.60 - 0.80)",
      "Source coherence (partial coherence degrades recovery)"
    ]
  },
  "G": {
    "dag": "S.scan.grid -> L.hadamard.complex -> F.fourier -> L.modulus_squared -> int.spatial",
    "vertices": [
