{
  "artifact_id": "L2-028",
  "layer": "L2",
  "parent_l1": "L1-028",
  "title": "Gaussian Matrix Sensing Mismatch-Only Spec",
  "spec_type": "mismatch_only",

  "six_tuple": {
    "omega": {
      "n1": [32, 2048], "n2": [32, 2048], "rank_r": [1, 50],
      "m_over_minmn": [2, 30], "noise_level": [0.001, 0.1],
      "rank_misspec": [0, 10], "measurement_noise_tail": [0.0, 0.2]
    },
    "E": {
      "forward": "y_k = <A_k, X> + n_k  with A_k ~ iid Gaussian; measurement_noise_tail allows sub-exponential outlier corruption",
      "operator": "gaussian_matrix_sensing_forward",
      "primitive_chain": "S.pattern.structured -> L.trace_inner_product -> int.temporal -> D.scalar",
      "inverse": "recover X in R^{n1 x n2} of rank r from m measurements"
    },
    "B": {"low_rank": true, "bounded_frobenius": true},
    "I": {"strategy": "spectral_init (top-r SVD of adjoint(y))"},
    "O": ["relative_Frobenius_error", "rank_recovery_accuracy", "residual_norm"],
    "epsilon_fn": "0.10 - 0.02 * log2(m_over_minmn / 2) + 0.02 * log10(noise_level / 0.001)"
  },

  "protocol_fields": {
    "input_format": {"measurements": "float32(m)", "operators": "float32(m, n1, n2) or ensemble_id"},
    "output_format": {"matrix": "float32(n1, n2)"},
    "baselines": [
      {"name": "SVT",              "method_sig": "L+O", "expected_rel_error": 0.08},
      {"name": "FPC-A",            "method_sig": "L+O", "expected_rel_error": 0.06},
      {"name": "AltGD-BM",         "method_sig": "L+O", "expected_rel_error": 0.04},
      {"name": "ScaledGD",         "method_sig": "L+O", "expected_rel_error": 0.03},
      {"name": "DeepPriorMatrix",  "method_sig": "L+N", "expected_rel_error": 0.02}
    ]
  },

  "ibenchmark_range": {
    "center_ibenchmark": {
      "rho": 1,
      "omega_tier": {"n1": 256, "n2": 256, "rank_r": 5, "m_over_minmn": 6, "noise_level": 0.01, "rank_misspec": 0, "measurement_noise_tail": 0.0},
      "epsilon": 0.05
    },
    "tier_bounds": {
      "n1": [32, 1024], "n2": [32, 1024], "rank_r": [1, 30],
      "m_over_minmn": [2, 20], "noise_level": [0.005, 0.1]
    },
    "proximity_threshold": 0.10
  },

  "d_spec": 0.55,
  "d_spec_notes": "Matrix sensing differs substantively from CASSI/CACTI/SPC (different solution_space=low_rank_matrix vs. {2D_spatial, 3D_*}); d_spec > 0.5 from all other B_compressive specs.",

  "s1_s4_gates": ["PASS", "PASS", "PASS", "PASS"],
