  "E": {
    "description": "A pencil or focused X-ray beam (synchrotron or microfocus source) excites K/L fluorescence of elements; fluorescent photons emitted isotropically are collected via energy-dispersive detector. Pencil-beam raster + rotation yields projections of elemental concentration; CT inversion reconstructs 3D elemental maps at ~1-10 um resolution.",
    "forward_model": "I_fluor(theta, t, E_k) = eta_det * omega_k * exp(-integral_self_abs) * c_k(r) * integral_exc dl",
    "world_state_x": "Elemental concentrations c_k(r) for K species in 3D",
    "observation_y": "Fluorescence yield vs. projection angle, translation, and energy",
    "physical_parameters_theta": [
      "Excitation energy (5-30 keV)",
      "Beam spot size (0.5-100 um)",
      "Detector resolution (~150 eV FWHM)",
      "Number of projections, translations",
      "Self-absorption correction (matrix-dependent)",
      "Scatter background (Compton + Rayleigh)"
    ]
  },

  "G": {
    "dag": "L.absorb.innerShell -> S.emit.fluor -> L.project.pencilbeam -> int.spatial",
    "vertices": ["L.absorb.innerShell", "S.emit.fluor", "L.project.pencilbeam", "int.spatial"],
    "arcs": ["L.absorb.innerShell -> S.emit.fluor", "S.emit.fluor -> L.project.pencilbeam", "L.project.pencilbeam -> int.spatial"],
    "L_DAG": 3.0,
    "n_c": 0
  },

  "W": {
    "existence": true,
    "uniqueness": "unique at full-angle, low-Z, thin samples; thick high-Z samples suffer self-absorption nonlinearity",
    "stability": "conditional",
    "condition_number_kappa": 500,
    "condition_number_effective": 30,
    "condition_number_mismatched": 1000,
    "regime": "Linear at low concentration; self-absorption breaks linearity (must be corrected iteratively). Limited-angle geometry adds ill-posedness."
  },

  "C": {
    "solver_class": "FBP-with-attenuation, iterative SART with self-absorption correction, ML-EM, learned XRF-Net",
    "convergence_rate_q": 2.0,
    "error_bound": "c_k uncertainty ~ sigma/sqrt(N_counts); self-absorption systematic 5-20%",
    "complexity": "FBP O(N^2 log); iterative O(iter * N_view * N_voxel)"
