  "p_benchmark": {
    "rho": 50,
    "dataset_p_benchmark": {
      "name": "CACTI-6 + DAVIS-SCI + UCF101-Sports union with parametric Omega sampling",
      "construction_method": "For each rho-weighted draw, sample Omega uniformly over declared bounds; 2x2 hard stitch when H*W > 480*480; seam_map in true_phi for evaluators.",
      "num_dev_instances": 200,
      "num_holdout_instances": 100
    },
    "tracks": {
      "track_A_stratified_worst_case": {
        "strata": [
          {"name": "S1_small",  "H_W_range": "<= 256^2",          "rep_difficulty": "easy"},
          {"name": "S2_medium", "H_W_range": "256^2 < HW <= 512^2", "rep_difficulty": "standard"},
          {"name": "S3_large",  "H_W_range": "512^2 < HW <= 1024^2","rep_difficulty": "hard"},
          {"name": "S4_xlarge", "H_W_range": "> 1024^2",           "rep_difficulty": "very_hard"}
        ],
        "samples_per_stratum": 5,
        "pass_condition": "min_i(PSNR_i) / epsilon_fn(Omega_centroid_s) >= 1.0 for all 4 strata"
      },
      "track_B_uniform_median": {
        "num_samples": 50,
        "pass_condition": "median_i(PSNR_i) / epsilon_fn(Omega_median) >= 1.0"
      },
      "track_C_mismatch_degradation": {
        "sweep_points": [
          {"phi": 0.00, "dx": 0.0,  "dt": 0.00, "theta": 0.000},
          {"phi": 0.25, "dx": 0.25, "dt": 0.025,"theta": 0.0375},
          {"phi": 0.50, "dx": 0.5,  "dt": 0.05, "theta": 0.075},
          {"phi": 0.75, "dx": 0.75, "dt": 0.075,"theta": 0.1125},
          {"phi": 1.00, "dx": 1.0,  "dt": 0.1,  "theta": 0.15}
        ],
        "scenes_per_point": 10,
        "degradation_score": "(1/4) * sum_{i=1..4} [(Q_norm(phi_i) + Q_norm(phi_{i+1}))/2]"
      }
    },
    "baselines": [
      {"name": "GAP-TV",       "track_A_Q": 0.32, "track_B_Q": 0.45, "track_C_Q": 0.58, "overall_Q": 0.45},
      {"name": "PnP-FFDNet",   "track_A_Q": 0.50, "track_B_Q": 0.65, "track_C_Q": 0.68, "overall_Q": 0.61},
      {"name": "EfficientSCI", "track_A_Q": 0.64, "track_B_Q": 0.82, "track_C_Q": 0.55, "overall_Q": 0.67}
    ]
